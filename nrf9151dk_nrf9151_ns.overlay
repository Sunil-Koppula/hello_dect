/*
 * Device-type selection pins (active-low, internal pull-up):
 *   P0.21  P0.23  →  type
 *     0      0       Gateway
 *     0      1       Anchor
 *     1      0       Sensor
 *     1      1       (reserved, defaults to Sensor)
 */
/ {
	chosen {
		nordic,pm-ext-flash = &gd25wb256;
	};

	device_type_pins {
		compatible = "gpio-keys";
		devtype_pin0: devtype_pin0 {
			gpios = <&gpio0 21 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Device type bit 0";
		};
		devtype_pin1: devtype_pin1 {
			gpios = <&gpio0 23 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Device type bit 1";
		};
	};
};

/* SPI3: Add PSRAM (APS6404L) sharing the bus with GD25WB256 flash.
 * SCK=P0.13, MOSI=P0.11, MISO=P0.12 (same as flash).
 * PSRAM CS=P0.10 (added as third CS on SPI3). */
&spi3 {
	cs-gpios = <&arduino_header 16 GPIO_ACTIVE_LOW>,  /* D10 */
		   <&gpio0 20 GPIO_ACTIVE_LOW>,            /* flash CS */
		   <&gpio0 10 GPIO_ACTIVE_LOW>;            /* PSRAM CS */

	psram: aps6404l@2 {
		compatible = "vnd,spi-device";
		reg = <2>;
		spi-max-frequency = <8000000>;
		status = "okay";
	};
};

/* I2C2: P0.30 = SDA, P0.31 = SCL (pinctrl already defined in board DTS). */
&i2c2 {
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;

	eeprom: eeprom@50 {
		compatible = "atmel,at24";
		reg = <0x50>;
		size = <DT_SIZE_K(256)>;
		pagesize = <256>;
		address-width = <16>;
		timeout = <10>;
	};
};
